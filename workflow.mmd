---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	process_video(process_video)
	process_captions(process_captions)
	process_easyocr(process_easyocr)
	summarize_captions([summarize_captions]):::last
	__start__ --> process_video;
	process_captions --> summarize_captions;
	process_easyocr --> summarize_captions;
	process_video --> process_captions;
	process_video --> process_easyocr;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
